{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for file system and updater access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "fs:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "fs:allow-appdata-recursive",
      "allow": [
        {
          "path": "$APPDATA/*"
        },
        {
          "path": "$APPLOCALDATA/*"
        }
      ]
    }
  ]
}
