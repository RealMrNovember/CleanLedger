{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "CleanLedger default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "process:allow-relaunch"
  ]
}
